@inject IJSRuntime JsRuntime
@using NotebookApp.Utils
@inject ThemeService Theme
@inject ILocalStorageService LocalStorage


@if (_isModalVisible)
{
    <!-- Задний фон (затемнение) -->
    <div class="modal-backdrop" @onclick="CloseModal"></div>

    <!-- Сам контейнер окна -->
    <div class="custom-modal" style="background-color: @GetTagColor(_lastNote!.Tag); color: @(Theme.IsDarkMode ? "#ffffff" : "#000000") !important;">
        <h3>Подтверждение</h3>
        @if (OsChecker.GetOperatingSystem() == "win")
        {
            <p>В вашей заметке есть дата, хотите добавить событие в этот день в google календарь?</p>
        }
        else
        {
            <p>В вашей заметке есть дата, хотите добавить событие в этот день в apple календарь?</p>
        }

        <div class="modal-buttons">
            @if (OsChecker.GetOperatingSystem() == "win")
            {
                <button class="btn btn-success" @onclick="HandleConfirmWin">Да</button>
            }
            else{
                <button class="btn btn-success" @onclick="HandleConfirmIos">Да</button>
            }
            <button class="btn btn-danger" @onclick="HandleCancel">Нет</button>
        </div>
    </div>
}

@code {
    
    
    [Parameter]
    public List<Note> Notes { get; set; } = new();
    
    [Parameter]
    public EventCallback<List<Note>> NotesChanged { get; set; }
    
    private Note? _lastNote;
    private DateParser _dateParser = new();
    

    // Переменная состояния окна (скрыто/показано)
    private bool _isModalVisible = false;

    // Метод открытия
    public void OpenModal(Note note)
    {
        _lastNote = note;
        _isModalVisible = true;
        StateHasChanged();
    }


    private void CloseModal() => _isModalVisible = false;



    private async Task HandleConfirmWin()
    {
        if (_lastNote != null)
        {


            if (_lastNote.Type == NoteType.Text)
            {
                var dates = _dateParser.ParseDates(_lastNote.Content);
                _lastNote.IsAddedToCalendar = true;
            
                var noteIndex = Notes.FindIndex(n => n.Id == _lastNote.Id);
                if (noteIndex != -1)
                {
                    Notes[noteIndex] = _lastNote;
                    await NotesChanged.InvokeAsync(Notes);
                }

                foreach (var date in dates)
                {
                    await JsRuntime.InvokeVoidAsync("open", GoogleCalendar.LinkToGoogleCalendar(_lastNote, date), "_blank");
                }
            }

            else
            {

                foreach (var dateEvent in _lastNote.DateEvents)
                {
                    await JsRuntime.InvokeVoidAsync("open", GoogleCalendar.LinkToGoogleCalendar(_lastNote.Title, dateEvent.Date, dateEvent.Event), "_blank");
                }
            }
        }

        CloseModal();
    }
    
    private async Task HandleConfirmIos()
    {
        if (_lastNote != null)
        {


            if (_lastNote.Type == NoteType.Text)
            {
                var dates = _dateParser.ParseDates(_lastNote.Content);
                _lastNote.IsAddedToCalendar = true;
            
                var noteIndex = Notes.FindIndex(n => n.Id == _lastNote.Id);
                if (noteIndex != -1)
                {
                    Notes[noteIndex] = _lastNote;
                    await NotesChanged.InvokeAsync(Notes);
                }

                await JsRuntime.InvokeVoidAsync("downloadIcsFile", "NotebookAppEvents.ics", AppleCalendar.AppleCalendarFile(_lastNote, dates));
            }

            else
            {
                
                
                
            }

            
            
            
            
            
            
            
        }

        CloseModal();
    }
    

    private void HandleCancel()
    {
        CloseModal();
    }
    
    
    private string GetTagColor(string tag) 
    {
        if (Theme.IsDarkMode)
        {
            // Глубокие, темные оттенки для темной темы (чтобы белый текст хорошо читался)
            return tag switch
            {
                "Учёба" => "#800f2f",      // Бордовый
                "Работа" => "#1b4332",     // Темно-зеленый
                "Личное" => "#03045e",     // Глубокий синий
                "Идеи" => "#744210",       // Горчичный
                _ => "#343a40"             // Темно-серый для "Без тега"
            };
        }
        else
        {
            // Мягкие, пастельные оттенки для светлой темы (для черного текста)
            return tag switch
            {
                "Учёба" => "#ffccd5",      // Нежно-розовый
                "Работа" => "#d8f3dc",     // Светло-салатовый
                "Личное" => "#caf0f8",     // Нежно-бирюзовый
                "Идеи" => "#fefae0",       // Мягкий желтый
                _ => "#e5e5e5"             // Светло-серый для "Без тега"
            };
        }
    }
    
}