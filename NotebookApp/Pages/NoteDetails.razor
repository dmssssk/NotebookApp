@page "/note/{Id:guid}"
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@inject ThemeService Theme
@using NotebookApp.Utils

@implements IDisposable

<PageTitle>@(isEditing ? "Редактирование" : "Просмотр заметки")</PageTitle>

<div class="container mt-4" style="max-width: 800px;">
    
    <button class="btn btn-outline-secondary mb-3" @onclick="GoBack">⬅️ Назад</button>

    @if (note == null)
    {
        <div class="alert alert-danger">Заметка не найдена или еще загружается...</div>
    }
    else
    {
        <div class="card shadow-sm border border-secondary p-4" 
             style="border-left: 5px solid @(isEditing ? editColor : note.Color); background-color: @((isEditing ? editColor : note.Color) + "20");">
            @if (isEditing)
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">Редактирование заметки</h4>
                    <!-- Приписка об обязательности заголовка -->
                    <small class="text-danger fw-bold">* Заголовок обязателен для заполнения</small>
                </div>
                
                <div class="mb-3 d-flex align-items-center gap-2">
                    <label class="form-label font-weight-bold mb-0">Цвет заметки:</label>
                    <div style="position: relative; width: 36px; height: 36px;">
                        <input type="color" @bind="editColor" @bind:event="oninput"
                               style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; border-radius: 50%;" />
                        <div style="width: 100%; height: 100%; border-radius: 50%; background-color: @(editColor + "20"); border: 2px solid #ccc; pointer-events: none;"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Заголовок</label>
                    <!-- Подсветка рамки нежно-красным, если пользователь стёр заголовок -->
                    <input type="text" 
                           class="form-control @(string.IsNullOrWhiteSpace(editTitle) ? "border-danger-subtle" : "")" 
                           value="@editTitle" 
                           @oninput="(e) => editTitle = e.Value?.ToString() ?? string.Empty" />
                </div>

                
                
                <div class="mb-3">
                    <label class="form-label font-weight-bold">Категория (Тег)</label>
                    <select class="form-select" @bind="editTag">
                        @foreach (var tag in availableTags)
                        {
                            <option value="@tag">@tag</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label font-weight-bold">Текст заметки</label>
                    <textarea class="form-control" rows="8" @bind="editContent"></textarea>
                </div>
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-success" @onclick="SaveEdit" disabled="@(string.IsNullOrWhiteSpace(editTitle))">💾 Сохранить</button>
                    <button class="btn btn-secondary" @onclick="CancelEdit">❌ Отмена</button>
                </div>
            }
            else
            {
                <!-- РЕЖИМ ПРОСМОТРА -->
                <div class="d-flex justify-content-between align-items-start border-bottom pb-2 mb-3">
                    <div>
                        <h2 class="text-primary mb-1">@note.Title</h2>
                        <!-- Адаптивный бейдж тега с авто-подбором цвета текста -->
                        <span class="badge mb-2" style="background-color: @GetTagColor(note.Tag); color: @(Theme.IsDarkMode ? "#ffffff" : "#000000") !important;">
                            Тег: 🏷️ @note.Tag
                        </span>
                        
                        <div class="mt-1 d-flex align-items-center gap-2">
                            <span class="text-muted small">Цвет заметки:</span>
                            <div style="width: 20px; height: 20px; border-radius: 50%; background-color: @(note.Color + "20"); border: 1px solid #ccc;"></div>
                            <span class="text-muted small">@note.Color</span>
                        </div>
                        
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-warning" @onclick="StartEdit">✏️ Редактировать</button>
                        <button class="btn btn-outline-danger" @onclick="DeleteNote">🗑️ Удалить</button>
                    </div>
                </div>

                <!-- Полный текст заметки -->
                <p class="text-dark fs-5" style="white-space: pre-wrap; color: var(--bs-body-color) !important;">@note.Content</p>

                <div class="text-muted mt-4 pt-2 border-top fs-6">
                    🕒 Дата создания: @note.CreatedAt.ToString("F")
                    <br />
                    ✏️ Дата редактирования: @note.EditedAt.ToString("F")
                    @if (note.IsAddedToCalendar)
                    {
                        <br \>
                        <span>
                            🗓️ Добавлено в календарь
                        </span>
                    }
                </div>

            }
        </div>
    }
</div>

<CalendarWindow @ref="ModalWindow"/>


@code {
    [Parameter] public Guid Id { get; set; } // Принимаем ID из URL

    private INote? note;
    private List<Note> allNotes = new();
    private List<string> availableTags = new() { "Без тега", "Учёба", "Работа", "Личное", "Идеи" };

    private bool isEditing = false;
    private string editTitle = "";
    private string editContent = "";
    private string editTag = "Без тега";
    private string editColor = "#ffffff";
    private DateParser _dateParser = new DateParser();

    
    private CalendarWindow ModalWindow { get; set; } = null!;
    
    
    protected override void OnInitialized()
    {
        // Подписываемся на динамическое изменение темы
        Theme.OnThemeChanged += StateHasChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Загружаем список из локального хранилища браузера
        var savedNotes = await LocalStorage.GetItemAsync<List<Note>>("my_notes");
        if (savedNotes != null)
        {
            allNotes = savedNotes;
            note = allNotes.FirstOrDefault(n => n.Id == Id);
        }
    }

    private void StartEdit()
    {
        if (note == null) return;
        editTitle = note.Title;
        editContent = note.Content;
        editTag = note.Tag;
        editColor = note.Color;
        isEditing = true;
    }
    
    private void CancelEdit()
    {
        isEditing = false;
    }

    private async Task SaveEdit()
    {
        if (note == null) return;

        note.Title = editTitle;
        note.Content = editContent;
        note.Tag = editTag;
        note.Color = editColor;
        note.EditedAt = DateTime.Now;
        
        var dates = _dateParser.ParseDates(note.Content);
        bool areEqual = dates.OrderBy(x => x).SequenceEqual(note.Dates.OrderBy(x => x));
        if (!areEqual)
        {
            note.Dates = dates;
        }

        await LocalStorage.SetItemAsync("my_notes", allNotes);
        isEditing = false;
        

        if (dates.Count != 0 && !areEqual)
        {
            ModalWindow.OpenModal(note);
        }
        
    }

    private async Task DeleteNote()
    {
        if (note == null) return;
        allNotes.Remove(note);
        await LocalStorage.SetItemAsync("my_notes", allNotes);
        Navigation.NavigateTo("/"); // Перенаправляем на главную
    }

    private void GoBack() => Navigation.NavigateTo("/");

    // Метод выбора цвета, адаптирующийся под темную и светлую темы
    private string GetTagColor(string tag) => Theme.IsDarkMode ? tag switch
    {
        "Учёба" => "#800f2f",
        "Работа" => "#1b4332",
        "Личное" => "#03045e",
        "Идеи" => "#744210",
        _ => "#343a40"
    } : tag switch
    {
        "Учёба" => "#ffccd5",
        "Работа" => "#d8f3dc",
        "Личное" => "#caf0f8",
        "Идеи" => "#fefae0",
        _ => "#e5e5e5"
    };

    // Отписываемся от события при уничтожении страницы для избежания утечек памяти
    public void Dispose()
    {
        Theme.OnThemeChanged -= StateHasChanged;
    }
}
