@page "/"
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@inject ThemeService Theme
@implements IDisposable
@using System.Net.Mime
@using NotebookApp.Utils
@inject IJSRuntime JsRuntime

<PageTitle>Мои Заметки</PageTitle>


<div class="container mt-4" style="max-width: 800px;">
    <h2 class="mb-4">📝 Мои Заметки </h2>
    
    <div class="mb-4">
        <div class="input-group shadow-sm">
            <span class="input-group-text">🔍</span>
            <input type="text" 
                   class="form-control border-secondary" 
                   placeholder="Поиск по заголовку или тексту заметки..." 
                   value="@SearchString" 
                   @oninput="OnSearchInput" />
            @if (!string.IsNullOrEmpty(SearchString))
            {
                <!-- Кнопка очистки поиска, если что-то введено -->
                <button class="btn btn-outline-secondary" @onclick="ClearSearch">❌</button>
            }
        </div>
    </div>

    <!-- Форма создания заметки -->
    <div class="card p-3 mb-4 shadow-sm border border-secondary">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5>Новая заметка</h5>
            <!-- Приписка об обязательности заголовка -->
            @if (_isIncorrectTitle)
            {
                <small class="text-danger fw-bold">* Заголовок обязателен для заполнения</small>
            }
        </div>
    
        <div class="mb-2">
            <!-- Добавили динамический класс валидации border-danger, если поле пустое -->
            <input type="text" 
                   class="form-control @(string.IsNullOrWhiteSpace(newTitle) ? "border-danger-subtle" : "")" 
                   placeholder="Заголовок заметки..." 
                   @bind="newTitle" 
                   @bind:event="oninput" />
        </div>

        <div class="mb-2">
            
            <select class="form-select" @bind="_noteType">
                <option value="Tasks">список</option>
                <option value="Text">текст</option>
            </select>
        </div>
            
        <div class="mb-2">
            <select class="form-select" @bind="newTag">
                @foreach (var tag in availableTags)
                {
                    <option value="@tag">@tag</option>
                }
            </select>
        </div>
        
        <div class="mb-2 d-flex align-items-center gap-2">
            <label class="form-label mb-0">Цвет заметки:</label>
            <div style="position: relative; width: 36px; height: 36px;">
                <input type="color" @bind="newNoteColor" @bind:event="oninput"
                       style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; border-radius: 50%;" />
                <div style="width: 100%; height: 100%; border-radius: 50%; background-color: @(newNoteColor + "20"); border: 2px solid #ccc; pointer-events: none;"></div>
            </div>
        </div>
        
        @if (_noteType == NoteType.Text)
        {
            <div class="mb-2">
                <textarea class="form-control" rows="3" placeholder="Текст заметки..." @bind="newContent"></textarea>
            </div>
        }
        else
        {

            
            <div class="mb-3">
                <label class="form-label fw-bold mb-2">Задачи списка</label>
                @if (_isIncorrectTasks)
                {
                    <small class="text-danger fw-bold right-side" style="margin-right: 10px">* для создания списка должен быть хоть одна заполненная задача</small>
                }
                <div class="d-flex flex-column gap-2">
                    @foreach (var task in newTasks)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <button type="button"
                                    class="invisible-btn"
                                    @onclick="() => task.IsCompleted = !task.IsCompleted">
                                <span>@(task.IsCompleted ? "✅" : "⬜")</span>
                            </button>
                            
                            <input type="text"
                                   class="form-control border-secondary" 
                                   style="min-width: 0;"
                                   id="@($"task-{task.Id}")"
                                   placeholder="Текст задачи..." 
                                   @bind="task.Text" 
                                   @bind:event="oninput"
                                   @onkeydown="(e) => HandleEditTaskKeyDown(e, task)" 
                                   @onkeyup="(e) => HandleEditTaskKeyUp(e, task)" />
                
                            <button type="button"
                                    title="удалить"
                                    class="invisible-btn"
                                    @onclick="() => RemoveTaskFromCreate(task)">
                                <span>❌</span>
                            </button>
                        </div>
                    }
                </div>
    
                <small class="text-secondary d-block mt-2">
                    💡 Нажмите <kbd>Enter</kbd> внутри любого поля, чтобы добавить новую задачу.
                </small>
            </div>
            
            
            
            
            
        }
        @if (_noteType == NoteType.Text)
        {
            <button class="btn btn-primary w-100" @onclick="AddNote">
                Добавить заметку
            </button>
        }
        else
        {
            <button class="btn btn-primary w-100" @onclick="SaveTaskList">
                Добавить список
            </button>
        }

    </div>
    
    <!-- Блок сортировки -->
    <div class="mb-3 d-flex align-items-center gap-3">
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted">Сортировать по:</span>
            <select @bind="sortBy" class="form-select w-auto" style="width: 220px;">
                <option value="CreatedAt">📅 Дате создания</option>
                <option value="EditedAt">📅 Дате редактирования</option>
                <option value="Star">⭐ Важности</option>
            </select>
        </div>
        
        <div class="btn-group" role="group">
            <button type="button" 
                    class="btn btn-sm @(sortDescending == false ? "btn-primary" : "btn-outline-secondary")" 
                    @onclick="() => sortDescending = false"
                    title="@GetUpButtonTitle()">
                ↑
            </button>
            <button type="button" 
                    class="btn btn-sm @(sortDescending == true ? "btn-primary" : "btn-outline-secondary")" 
                    @onclick="() => sortDescending = true"
                    title="@GetDownButtonTitle()">
                ↓
            </button>
        </div>
    </div>

    <!-- Список заметок -->
    @if (notes.Count == 0)
    {
        <p><em>Загрузка хранилища...</em></p>
    }
    else if (!notes.Any())
    {
        <div class="alert alert-info text-center">У вас пока нет ни одной заметки. Создайте первую выше!</div>
    }
    else
    {
        
        <div class="row">
            @if (!FilteredNotes.Any())
            {
                <div class="alert alert-secondary text-center">Нет заметок содержащих "@SearchString" в заголовке или теле</div>
            }
            else
            {
            @foreach (var note in FilteredNotes)
            {
                <div class="col-12 mb-3">
                    <!-- Вся карточка кликабельна для перехода внутрь -->
                    <div class="card h-100 shadow-sm border border-secondary card-hover"
                         style="cursor: pointer; border-left: 5px solid @note.Color; background-color: @(note.Color + "20");"
                         @onclick="() => NavigateToNote(note.Id)">

                        @if (!note.IsPinned)
                        {
                            <button title="Закрепить" class="invisible-btn right-side" type="button" @onclick="() => Pin(note, true)" @onclick:stopPropagation>
                                <img src="icons/pin/PinWhite.png" alt="Иконка кнопки">
                            </button>
                        }
                        else
                        {
                            <button title="Открепить" class="invisible-btn right-side" type="button" @onclick="() => Pin(note, false)" @onclick:stopPropagation>
                                <img src="icons/pin/PinBlack.png" alt="Иконка кнопки">
                            </button>
                        }


                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title text-primary mb-1">
                                    @note.Title


                                    @if (!note.Star)
                                    {
                                        <button title="Важное" class="invisible-btn" type="button" style="margin-left: 10px; width: 17px; height: 17px" @onclick="() => Star(note, true)" @onclick:stopPropagation>
                                            <img src="icons/star/starBlack.png" alt="Иконка кнопки">
                                        </button>
                                    }
                                    else
                                    {
                                        <button title="Важное" class="invisible-btn" type="button" style="margin-left: 10px; width: 17px; height: 17px" @onclick="() => Star(note, false)" @onclick:stopPropagation>
                                            <img src="icons/star/starYellow.png" alt="Иконка кнопки">
                                        </button>
                                    }

                                </h5>
                                <div>
                                    @if (note.Tag != "Без тега")
                                    {
                                        <span class="badge mb-2" style="background-color: @GetTagColor(note.Tag); color: @(Theme.IsDarkMode ? "#ffffff" : "#000000") !important; margin-right: 20px">
                                            🏷️ @note.Tag
                                        </span>
                                    }
                                </div>
                            </div>
                            @if (note.Type == NoteType.Text)
                            {
                                <p class="card-text text-secondary" style="white-space: pre-wrap;">
                                    @(note.Content.Length > 150 ? note.Content.Substring(0, 150) + "..." : note.Content)
                                </p>
                            }
                            else
                            {
                                for(int i = 0; i < note.Tasks.Count && i < 3; i++)
                                {
                                    <button type="button"
                                            class="invisible-btn"
                                            @onclick="() => note.Tasks[i].IsCompleted = !note.Tasks[i].IsCompleted">
                                        <span>@(note.Tasks[i].IsCompleted ? "✅" : "⬜")</span>
                                    </button>
                                    
                                    <span class="card-text text-secondary" style="white-space: pre-wrap; text-decoration: @(note.Tasks[i].IsCompleted ? "line-through" : "none");">
                                        @(note.Tasks[i].Text.Length > 50 ? note.Tasks[i].Text.Substring(0, 50) + "..." : note.Tasks[i].Text)
                                    </span>
                                    <br>
                                }

                                if (note.Tasks.Count > 3)
                                {
                                    <span class="card-text text-secondary" style="font-size: 40px; margin-top: -50px; display: inline-block;">...</span>
                                }
                                
                                
                            }

                            
                            <small class="text-muted d-block mt-2">🕒 @note.CreatedAt.ToString("g")</small>
                            <small class="text-muted d-block mt-2">✏️ @note.EditedAt.ToString("g")</small>
                            @if (note.IsAddedToCalendar)
                            {
                                <span class="right-side text-muted" style="margin-top: -10px; margin-right: 10px">
                                    🗓️ добавлено в календарь
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
            }
        </div>
    }
</div>

<CalendarWindow @ref="ModalWindow" Notes="@notes" NotesChanged="@OnNotesChanged"/>


@code {
    private List<Note> notes = new();
    private List<string> availableTags = new() { "Без тега", "Учёба", "Работа", "Личное", "Идеи" };

    private List<OneTask> newTasks = new() { new OneTask() };
    private bool _isIncorrectTasks;
    
    
    private Dictionary<OneTask, ElementReference> taskInputs = new();
    private OneTask? taskToFocus;
    
    private void RegisterInput(OneTask task, ElementReference element)
    {
        taskInputs[task] = element;
    }
    
    
    private string newTitle = "";
    private string newContent = "";
    private NoteType _noteType = NoteType.Text;
    private string newTag = "Без тега";
    private string newNoteColor = "#ffffff";
    private string SearchString { get; set; } = "";
    private bool _isIncorrectTitle;
    private bool TitleIsIncorrect;
    private string sortBy = "EditedAt";
    private bool sortDescending = true;
    
    private CalendarWindow ModalWindow { get; set; } = null!;

    private DateParser _dateParser = new();
    
    
    private void RemoveTaskFromCreate(OneTask task)
    {
        newTasks.Remove(task);
    
        // Если удалили вообще все строки, оставим одну пустую, чтобы было где писать
        if (!newTasks.Any())
        {
            newTasks.Add(new OneTask());
        }
    }
    
        private async Task HandleEditTaskKeyDown(KeyboardEventArgs e, OneTask currentTask)
    {
        if (newTasks.Any(t => string.IsNullOrWhiteSpace(t.Text)))
        {
            return;
        }
        
        if (e.Key == "Enter")
        {
            if (newTasks.Any(t => string.IsNullOrWhiteSpace(t.Text))) return;
            var task = new OneTask();
            int index = newTasks.IndexOf(currentTask);
            if (index != -1) newTasks.Insert(index + 1, task);
            else newTasks.Add(task);

            await Task.Delay(20);
            
            await JsRuntime.InvokeVoidAsync("focusElement", $"task-{task.Id}");
            
        }
    }

    private void HandleEditTaskKeyUp(KeyboardEventArgs e, OneTask currentTask)
    {
        // А удаление переносим сюда, когда клавиша уже отпущена и текст стёрт
        if (e.Key == "Backspace" || e.Key == "Delete")
        {
            // Проверяем: если задача стала пустой
            if (string.IsNullOrWhiteSpace(currentTask.Text))
            {
                // И если в списке больше одной пустой задачи — удаляем текущую
                if (newTasks.Count(x => string.IsNullOrWhiteSpace(x.Text)) > 1)
                {
                    newTasks.Remove(currentTask);
                }
            }
        }
    }
    
    private async Task SaveTaskList()
    {
        if (string.IsNullOrWhiteSpace(newTitle))
        {
            _isIncorrectTitle = true;
            return;
        }

        _isIncorrectTitle = false;

        if (newTasks.Count == 1 && string.IsNullOrEmpty(newTasks[0].Text))
        {
            _isIncorrectTasks = true;
            return;
        }

        _isIncorrectTasks = false;

        List<DateEvent> dateEvents = [];
        
        
        foreach (var task in newTasks)
        {
            foreach (var date in _dateParser.ParseDates(task.Text))
            {
                dateEvents.Add(new DateEvent(date, task.Text));
                
            }
        }



        var note = new Note
        {
            Type = NoteType.Tasks,
            Title = newTitle,
            Tasks = new List<OneTask>(string.IsNullOrEmpty(newTasks[^1].Text) ? newTasks[..^1] : newTasks),
            Tag = newTag,
            DateEvents = dateEvents,
            Color = newNoteColor
        };

        notes.Add(note);

        await LocalStorage.SetItemAsync("my_notes", notes);
        
        newTitle = ""; newContent = ""; newTag = "Без тега"; newNoteColor = "#ffffff"; newTasks.Clear(); newTasks.Add( new OneTask() );
        
        if (dateEvents.Count != 0)
        {
            ModalWindow.OpenModalCreate(note);
        }
        
    }

    private string GetUpButtonTitle()
    {
        if (sortBy == "Star")
            return "Важные после";
        return "Сначала старые";
    }

    private string GetDownButtonTitle()
    {
        if (sortBy == "Star")
            return "Важные сначала";
        return "Сначала новые";
    }

    private IEnumerable<Note> FilteredNotes
    {
        get
        {
            var filtered = notes.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(SearchString))
            {
                filtered = filtered.Where(n => n.Title.Contains(SearchString, StringComparison.OrdinalIgnoreCase) || 
                                               n.Content.Contains(SearchString, StringComparison.OrdinalIgnoreCase));
            }

            var pinned = filtered.Where(n => n.IsPinned);
            var unpinned = filtered.Where(n => !n.IsPinned);

            var sortedPinned = pinned
                .OrderByDescending(n => n.Star)
                .ThenByDescending(n => n.EditedAt)
                .ThenByDescending(n => n.CreatedAt);
            
            IOrderedEnumerable<Note> sortedUnpinned;
            
            switch (sortBy)
            {
                case "CreatedAt":
                    if (sortDescending)
                        sortedUnpinned = unpinned.OrderByDescending(n => n.CreatedAt);
                    else
                        sortedUnpinned = unpinned.OrderBy(n => n.CreatedAt);
                    break;
                    
                case "EditedAt":
                    if (sortDescending)
                        sortedUnpinned = unpinned.OrderByDescending(n => n.EditedAt);
                    else
                        sortedUnpinned = unpinned.OrderBy(n => n.EditedAt);
                    break;
                    
                case "Star":
                default:
                    if (sortDescending)
                        sortedUnpinned = unpinned.OrderByDescending(n => n.Star);
                    else
                        sortedUnpinned = unpinned.OrderBy(n => n.Star);
                    break;
            }

            
            return sortedPinned.Concat(sortedUnpinned);
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchString = e.Value?.ToString() ?? "";
    }

    private void ClearSearch()
    {
        SearchString = "";
    }
    
    private async Task OnNotesChanged(List<Note> updatedNotes)
    {
        notes = updatedNotes;
        await LocalStorage.SetItemAsync("my_notes", notes);
        StateHasChanged();
    }
    

    protected override async Task OnInitializedAsync()
    {
        // 1. Загружаем заметки
        var savedNotes = await LocalStorage.GetItemAsync<List<Note>>("my_notes");
        if (savedNotes != null) notes = savedNotes;
        
        // Когда пользователь нажмет кнопку в меню, этот метод поменяет тему страницы, и заставит её обновиться
        Theme.OnThemeChanged += StateHasChanged;
    }
    
    private string GetTagColor(string tag) 
    {
        if (Theme.IsDarkMode)
        {
            // Глубокие, темные оттенки для темной темы (чтобы белый текст хорошо читался)
            return tag switch
            {
                "Учёба" => "#800f2f",      // Бордовый
                "Работа" => "#1b4332",     // Темно-зеленый
                "Личное" => "#03045e",     // Глубокий синий
                "Идеи" => "#744210",       // Горчичный
                _ => "#343a40"             // Темно-серый для "Без тега"
            };
        }
        // Мягкие, пастельные оттенки для светлой темы (для черного текста)
        return tag switch
        {
            "Учёба" => "#ffccd5",      // Нежно-розовый
            "Работа" => "#d8f3dc",     // Светло-салатовый
            "Личное" => "#caf0f8",     // Нежно-бирюзовый
            "Идеи" => "#fefae0",       // Мягкий желтый
            _ => "#e5e5e5"             // Светло-серый для "Без тега"
        };
    }


    private async Task Pin(Note note, bool pin)
    {
        note.IsPinned = pin;
        await LocalStorage.SetItemAsync("my_notes", notes);
    }
    
    
    private async Task Star(Note note, bool star)
    {
        note.Star = star;
        await LocalStorage.SetItemAsync("my_notes", notes);
    }
    
    
    private void NavigateToNote(Guid id)
    {
        Navigation.NavigateTo($"/note/{id}");
    }

    private async Task AddNote()
    {
            if (string.IsNullOrWhiteSpace(newTitle))
            {
                _isIncorrectTitle = true;
                return;
            }

            _isIncorrectTitle = false;
        
        
            var dates = _dateParser.ParseDates(newContent);
            var note = new Note { Title = newTitle, Content = newContent, Tag = newTag , Dates = dates, Color = newNoteColor};
            notes.Add(note);
            await LocalStorage.SetItemAsync("my_notes", notes);
            newTitle = ""; newContent = ""; newTag = "Без тега"; newNoteColor = "#ffffff";
        

            if (dates.Count != 0)
            {
                ModalWindow.OpenModalCreate(note);
            }
        
    }
    
    // Отписывает страницу от обновлений, когда пользователь уходит на другую вкладку
    public void Dispose()
    {
        Theme.OnThemeChanged -= StateHasChanged;
    }
}

