@page "/filter"
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject ThemeService Theme
@implements IDisposable

<PageTitle>Фильтрация заметок</PageTitle>

<div class="container mt-4" style="max-width: 800px;">
    <h2 class="mb-4">🔍 Фильтрация моих заметок</h2>

    <!-- Кнопки выбора тега -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        <button class="btn @(selectedTag == "Все" ? "btn-dark" : "btn-outline-dark")" @onclick='() => selectedTag = "Все"'>
            🌐 Все (@notes.Count)
        </button>
        @foreach (var tag in availableTags)
        {
            var count = notes.Count(n => n.Tag == tag);
            <button class="btn btn-sm" 
                    style="background-color: @(selectedTag == tag ? GetTagColor(tag) : "transparent"); border: 1px solid @GetTagColor(tag); font-weight: @(selectedTag == tag ? "bold" : "normal");"
                    @onclick="() => selectedTag = tag">
                🏷️ @tag (@count)
            </button>
        }
    </div>
    
    <div class="mb-4">
        <div class="input-group shadow-sm">
            <span class="card h-100 shadow-sm border border-secondary card-hover">🔍</span>
            <input type="text" 
                   class="form-control border-secondary" 
                   placeholder="Поиск по названию или тексту заметки..." 
                   value="@SearchString" 
                   @oninput="OnSearchInput" />
            @if (!string.IsNullOrEmpty(SearchString))
            {
                <!-- Кнопка очистки поиска, если что-то введено -->
                <button class="btn btn-outline-secondary" @onclick="ClearSearch">❌</button>
            }
        </div>
    </div>

    <!-- Список отфильтрованных заметок -->
    <div class="row">
        @if (!FilteredNotes.Any())
        {
            <div class="alert alert-secondary text-center">Нет заметок с таким тегом.</div>
        }
        else
        {
            @foreach (var note in FilteredNotes)
            {
                <div class="col-12 mb-3">
                    <div class="card h-100 shadow-sm border border-secondary" style="cursor: pointer;" @onclick='() => Navigation.NavigateTo($"/note/{note.Id}")'>
                        
                        @if (!note.IsPinned)
                        {
                            <button title="закрепить" class="invisible-btn right-side" type="button" @onclick="() => Pin(note, true)" @onclick:stopPropagation>
                                <img src="icons/pin/PinWhite.png" alt="Иконка кнопки">
                            </button>
                        }
                        else
                        {
                            <button title="открепить" class="invisible-btn right-side" type="button" @onclick="() => Pin(note, false)" @onclick:stopPropagation>
                                <img src="icons/pin/PinBlack.png" alt="Иконка кнопки">
                            </button>
                        }
                        
                        
                        <div class="card-body">
                            <h5 class="card-title text-primary">
                                @note.Title <span class="text-muted fs-6"></span>
                                
                                @if (!note.Star)
                                {
                                    <button title="избранное" class="invisible-btn" type="button" style="margin-left: 10px;" @onclick="() => Star(note, true)" @onclick:stopPropagation>
                                        <img src="icons/star/starBlack.png" alt="Иконка кнопки">
                                    </button>
                                }
                                else
                                {
                                    <button title="избранное" class="invisible-btn" type="button" style="margin-left: 10px;" @onclick="() => Star(note, false)" @onclick:stopPropagation>
                                        <img src="icons/star/starYellow.png" alt="Иконка кнопки">
                                    </button>
                                }
                                
                                
                            </h5>
                            <span class="badge mb-2" style="background-color: @GetTagColor(note.Tag); color: @(Theme.IsDarkMode ? "#ffffff" : "#000000") !important;">🏷️ @note.Tag</span>
                            <p class="card-text text-secondary" style="white-space: pre-wrap;">
                                @(note.Content.Length > 150 ? note.Content.Substring(0, 150) + "..." : note.Content)
                            </p>
                            <small class="text-muted">🕒 Создано: @note.CreatedAt.ToString("g")</small>
                            @if (note.EditedAt != note.CreatedAt)
                            {
                                <small class="text-muted d-block mt-2">✏️ Изменено: @note.EditedAt.ToString("g")</small>
                            }
                        </div>
                    </div>
                </div>
            }

        }
    </div>
</div>

@code {
    private List<Note> notes = new();
    private List<string> availableTags = new() { "Без тега", "Учёба", "Работа", "Личное", "Идеи" };
    private string selectedTag = "Все";
    private string SearchString { get; set; } = "";

    
    private IEnumerable<Note> FilteredNotes
    {
        get
        {
            IEnumerable<Note> filterTags = selectedTag == "Все" ? notes.OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.CreatedAt).ToList() 
                : notes.Where(n => n.Tag == selectedTag).OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.CreatedAt).ToList();
            
            
            if (string.IsNullOrWhiteSpace(SearchString))
            {
                return filterTags;
            }

            return filterTags
                .Where(n => n.Title.Contains(SearchString, StringComparison.OrdinalIgnoreCase) || 
                            n.Content.Contains(SearchString, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.EditedAt);
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchString = e.Value?.ToString() ?? "";
    }

    private void ClearSearch()
    {
        SearchString = "";
    }
    
    private async Task Star(Note note, bool star)
    {
        note.Star = star;
        await LocalStorage.SetItemAsync("my_notes", notes);
    }
    
    

    protected override async Task OnInitializedAsync()
    {
        var savedNotes = await LocalStorage.GetItemAsync<List<Note>>("my_notes");
        if (savedNotes != null) notes = savedNotes;

        // Подписываемся на динамическое обновление темы
        Theme.OnThemeChanged += StateHasChanged;
    }

    // Метод определения цвета (точно такой же, как на главной)
    private string GetTagColor(string tag) => Theme.IsDarkMode ? tag switch
    {
        "Учёба" => "#800f2f",
        "Работа" => "#1b4332",
        "Личное" => "#03045e",
        "Идеи" => "#744210",
        _ => "#343a40"
    } : tag switch
    {
        "Учёба" => "#ffccd5",
        "Работа" => "#d8f3dc",
        "Личное" => "#caf0f8",
        "Идеи" => "#fefae0",
        _ => "#e5e5e5"
    };
    
    private async Task Pin(Note note, bool pin)
    {
        note.IsPinned = pin;
        await LocalStorage.SetItemAsync("my_notes", notes);
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= StateHasChanged;
    }
}

